APP_NAME=BioLight
APP_ENV=production
APP_DEBUG=false
# Сгенерируйте через `docker compose --env-file .env.docker run --rm api php artisan key:generate --show`
# и вручную вставьте сюда полное значение вида `base64:...`
APP_KEY=
LOG_LEVEL=warning
DEFAULT_MODE=prod

# Основной публичный URL сайта.
APP_URL=https://example.com

# Прямой URL админки/API. Если отдельный домен не нужен, оставьте пусто.
ADMIN_URL=https://admin.example.com
ASSET_URL=

# Legacy fallback. Можно не использовать, если ниже заполнены FRONTEND_/BACKEND_ переменные.
DOMAIN=example.com
SERVER_ALIASES=www.example.com

# Домен сайта.
FRONTEND_DOMAIN=example.com
FRONTEND_SERVER_ALIASES=www.example.com

# Отдельный домен для admin/api/phpMyAdmin. Если не нужен, укажите тот же домен, что и FRONTEND_DOMAIN.
BACKEND_DOMAIN=admin.example.com
BACKEND_SERVER_ALIASES=

MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=biolight
MYSQL_USER=biolight
MYSQL_PASSWORD=change_me_user

MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=site@example.com
MAIL_FROM_NAME=BioLight
FEEDBACK_NOTIFICATION_EMAIL=office@example.com

CERTBOT_EMAIL=admin@example.com
CERTBOT_PRIMARY_DOMAIN=example.com
CERTBOT_DOMAINS=example.com,www.example.com,admin.example.com
CERTBOT_RENEW_INTERVAL=12h
CERTBOT_STAGING=false
CERTBOT_FORCE_RENEWAL=false
CERTBOT_ONE_SHOT=false

# Внутренний URL API для SSR и контейнеров.
NUXT4_API_BASE_URL=http://api:8080/api/

# Публичный URL API для браузера.
# Можно оставить /api/, если frontend домен тоже проксирует API.
NUXT4_API_BASE_PUBLIC=/api/

# Канонический URL frontend сайта для SEO/hreflang.
NUXT4_SITE_URL=https://example.com

# Явный origin frontend сайта. Нужен для корректной генерации абсолютных ссылок на ассеты в некоторых компонентах.
NUXT4_BROWSER_ORIGIN=https://example.com

# Явный origin, откуда брать /uploads.
# Если frontend и backend разнесены по доменам, обычно это https://admin.example.com
NUXT4_UPLOADS_ORIGIN=https://admin.example.com

# Разрешённые хосты для Nuxt Image/IPX.
NUXT4_IMAGE_DOMAINS=api,localhost,127.0.0.1,example.com,www.example.com,admin.example.com

NUXT4_PORT=3001
QUEUE_CONNECTION=database
BACKPACK_REGISTRATION_OPEN=false

RUN_MIGRATIONS=false
NGINX_RELOAD_INTERVAL=5m
TZ=Europe/Kiev

# Для прода лучше указывать абсолютный путь вне репозитория, например /opt/biolight/data
DOCKER_DATA_DIR=.docker/volumes

DEV_NGINX_PORT=8088
DEV_NUXT4_PORT=3080
