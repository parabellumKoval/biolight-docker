FROM node:22-bookworm-slim AS deps

WORKDIR /app

COPY package*.json ./
RUN npm install

FROM node:22-bookworm-slim AS dev

WORKDIR /app

ENV NODE_ENV=development
ENV NUXT_HOST=0.0.0.0
ENV NUXT_PORT=3000

CMD ["npm", "run", "dev"]

FROM deps AS builder

ARG NUXT4_SITE_URL
ARG NUXT4_API_BASE_PUBLIC
ARG NUXT4_BROWSER_ORIGIN
ARG NUXT4_UPLOADS_ORIGIN
ARG NUXT4_IMAGE_DOMAINS

ENV NUXT4_SITE_URL=${NUXT4_SITE_URL}
ENV NUXT4_API_BASE_PUBLIC=${NUXT4_API_BASE_PUBLIC}
ENV NUXT4_BROWSER_ORIGIN=${NUXT4_BROWSER_ORIGIN}
ENV NUXT4_UPLOADS_ORIGIN=${NUXT4_UPLOADS_ORIGIN}
ENV NUXT4_IMAGE_DOMAINS=${NUXT4_IMAGE_DOMAINS}

COPY . ./

RUN npm run build

FROM node:22-bookworm-slim

WORKDIR /app

ENV NODE_ENV=production
ENV NUXT_HOST=0.0.0.0
ENV NUXT_PORT=3000

COPY --from=builder /app /app

EXPOSE 3000

CMD ["npm", "run", "start"]
